{
  "name": "@learning-os/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:prod": "tsc -p tsconfig.prod.json && node ./scripts/copy-package-json.mjs",
    "dev": "tsx watch src/main.ts",
    "dev:server": "tsx watch src/main.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "DATABASE_URL=file:./prisma/dev.db prisma db push",
    "start": "node dist-prod/apps/server/src/main.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@learning-os/contracts": "workspace:*",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-fsrs": "^4.5.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/node": "^24.0.15",
    "prisma": "^6.12.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
